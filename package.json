{
  "name": "tomcat-auto-deploy",
  "displayName": "Tomcat Auto Deploy",
  "description": "저장 시 자동 컴파일/deploy + Tomcat 시작/중지 + Hot Deploy",
  "version": "0.0.1",
  "publisher": "your-publisher-name",
  "engines": { "vscode": "^1.74.0" },
  "icon": "tomcat-logo.png",
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "extensionKind": ["workspace"],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      { "command": "tomcatAutoDeploy.start",       "title": "Tomcat: 시작",           "icon": "$(play)"        },
      { "command": "tomcatAutoDeploy.stop",        "title": "Tomcat: 중지",           "icon": "$(debug-stop)"  },
      { "command": "tomcatAutoDeploy.forceStop",   "title": "Tomcat: 강제 중지",      "icon": "$(close)"       },
      { "command": "tomcatAutoDeploy.restart",     "title": "Tomcat: 재시작",         "icon": "$(refresh)"     },
      { "command": "tomcatAutoDeploy.openBrowser", "title": "Tomcat: 브라우저 열기",   "icon": "$(globe)"       },
      { "command": "tomcatAutoDeploy.showOutput",  "title": "Tomcat: Output 보기",    "icon": "$(output)"      },
      { "command": "tomcatAutoDeploy.showLocalhostLog", "title": "Tomcat: Localhost 로그", "icon": "$(file-text)" },
      { "command": "tomcatAutoDeploy.openServerXml", "title": "Tomcat: server.xml 열기", "icon": "$(file-code)"   },
      { "command": "tomcatAutoDeploy.configure",   "title": "Tomcat: 설정 열기",      "icon": "$(gear)"        }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "tomcatExplorer",
          "title": "Tomcat",
          "icon": "tomcat-icon.svg"
        }
      ]
    },
    "views": {
      "tomcatExplorer": [
        {
          "id": "tomcatServerView",
          "name": "서버",
          "icon": "tomcat-icon.svg",
          "contextualTitle": "Tomcat 서버"
        }
      ]
    },
    "menus": {
      "view/title": [
        { "command": "tomcatAutoDeploy.start",   "when": "view == tomcatServerView && !tomcatAutoDeploy.running", "group": "navigation@1" },
        { "command": "tomcatAutoDeploy.stop",      "when": "view == tomcatServerView && tomcatAutoDeploy.running",  "group": "navigation@1" },
        { "command": "tomcatAutoDeploy.forceStop", "when": "view == tomcatServerView && tomcatAutoDeploy.running",  "group": "navigation@2" },
        { "command": "tomcatAutoDeploy.restart", "when": "view == tomcatServerView && tomcatAutoDeploy.running",  "group": "navigation@3" },
        { "command": "tomcatAutoDeploy.configure", "when": "view == tomcatServerView", "group": "navigation@4" }
      ]
    },
    "configuration": {
      "title": "Tomcat Auto Deploy",
      "properties": {
        "tomcatAutoDeploy.catalinaHome": {
          "type": "string",
          "default": "",
          "description": "Tomcat 설치 경로 (CATALINA_HOME). 예: /opt/tomcat"
        },
        "tomcatAutoDeploy.javaHome": {
          "type": "string",
          "default": "",
          "description": "JAVA_HOME 경로 (비어있으면 환경변수 사용)"
        },
        "tomcatAutoDeploy.javaSourceRoot": {
          "type": "string",
          "default": "src/main/java",
          "description": "Java 소스 루트 (workspace 상대경로)"
        },
        "tomcatAutoDeploy.webContentRoot": {
          "type": "string",
          "default": "src/main/webapp",
          "description": "JSP/Static 파일 루트 (workspace 상대경로)"
        },
        "tomcatAutoDeploy.classpath": {
          "type": "array",
          "default": [],
          "description": "추가 classpath jar 목록. 예: [\"/opt/tomcat/lib/servlet-api.jar\"]"
        },
        "tomcatAutoDeploy.port": {
          "type": "number",
          "default": 8080,
          "description": "Tomcat HTTP 포트"
        },
        "tomcatAutoDeploy.debugPort": {
          "type": "number",
          "default": 5005,
          "description": "JPDA 디버그 포트 (HotSwap 용)"
        },
        "tomcatAutoDeploy.redirectPort": {
          "type": "number",
          "default": 8443,
          "description": "HTTPS 리다이렉트 포트 (다중 인스턴스 시 충돌 방지용)"
        },
        "tomcatAutoDeploy.contextPath": {
          "type": "string",
          "default": "/",
          "description": "웹 애플리케이션 컨텍스트 경로. 예: / (ROOT), /monitoring, /api"
        },
        "tomcatAutoDeploy.javaOpts": {
          "type": "string",
          "default": "",
          "editPresentation": "multilineText",
          "description": "Tomcat 기동 시 JAVA_OPTS에 추가할 JVM 옵션. 줄바꿈으로 구분하여 입력. 예:\n-Xms512m\n-Xmx1024m\n-Dspring.profiles.active=dev"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "node -e \"require('fs').writeFileSync('build-info.json', JSON.stringify({ buildTime: new Date().toISOString() }))\""
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@types/node": "^18.0.0"
  }
}
